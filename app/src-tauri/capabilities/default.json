{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "pty:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.cmdop.com/**" },
        { "url": "https://*.cmdop.com/**" }
      ]
    }
  ]
}
